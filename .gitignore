# ==============================================================================
# Go Baseline Configurations
# ==============================================================================
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# ==============================================================================
# Terraform & OpenTofu Protection Rules
# ==============================================================================
# Core state and runtime files
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Crash logs
crash.log
crash.*.log

# Terraform configuration overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local CLI configuration files
.terraformrc
terraform.rc

# Hidden Terraform working directories
.terraform/

# Terraform variable files (Contains cloud/infrastructure secrets)
*.tfvars
*.tfvars.json

# ==============================================================================
# Cloud-Native & DevOps Platforms Custom Additions
# ==============================================================================
# Local cluster state & tokens
*.kubeconfig
*kubeconfig.yaml
*kubeconfig
.kube/

# Secrets, Credentials, and Cloud Keys
*.pem
*.key
*.pub
*.passwd
.env
.env.*
!.env.example
secrets.yaml
*secret*.yaml

# Local Helm & Kustomize cache/builds
.helm/
/.kustomize/
dist/

# ONLY ignore deep dependencies, do NOT ignore your root custom charts directory
**/charts/*.tgz
**/charts/subcharts/

# Editor / IDE / OS Tooling
.idea/
.vscode/
.DS_Store